# Copy to `.env.local` for local dev (never commit secrets).

# Mapbox GL — required for maps including `/map/`, trip planner, town maps, etc.
# Create a token at https://account.mapbox.com/access-tokens/
NEXT_PUBLIC_MAPBOX_TOKEN=

# Optional (future): custom PMTiles or TileJSON URL for raster-dem — not used by MVP terrain-rgb.
# NEXT_PUBLIC_TERRAIN_TILES_URL=
